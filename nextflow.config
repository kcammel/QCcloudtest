

includeConfig 'conf/sturgeon.config'


manifest {
    name = "princessmaximacenter/sturgeon_classifier"
    contributors = [
        [
            name: "Karlijn Cammel",
            affiliation: "Princess Maxima Center",
            contribution: ['author', 'maintainer']
        ]
    ]
    homePage = ""
    description = "Sturgeon Classifier for Nanopore Methylation Sequencing data"
    mainScript = "main.nf"
    defaultBranch = "main"
    nextflowVersion = ">=25.04.6"
    version = "0.1.0"
}


plugins {
    id 'nf-schema@2.5.1'
}

params {
    input = ""
    outdir = "sturgeon_classification"
    barcode = ""
    model = "/Users/k.v.cammel/Developer/public_repos/sturgeon/sturgeon/include/models/general.zip"
    shutdown_file = "shutdown.flag"
    lock = "script.lock"
}


validation {
    help {
        command = "Nextflow run main.nf --input location/of/bam_files --outdir name_of_output_directory --barcode [DIGIT] --model location/of/model.zip"
        beforeText = "This pipeline runs the Sturgeon CNS classifier on Nanopore Methylation sequencing data"
        enabled = true
    }
}
workDir = 'gs://pmc-bdc-dev-nextflow-wd/work'

// * Basic settings for GCP Batch Executor
process.executor = 'google-batch'

google {
    project = 'pmc-gcp-bdc-d-pip-nextflow'
    location = 'europe-west4'
    batch {
        usePrivateAddress = 'true'
        spot = 'true'
        network = 'projects/pmc-vpc-res-private-20gx/global/networks/shared-vpc-res-priv-dev'
        subnetwork = 'projects/pmc-vpc-res-private-20gx/regions/europe-west4/subnetworks/subnet-res-priv-dev'
        serviceAccountEmail = 'sa-nextflow-runner@pmc-gcp-bdc-d-pip-nextflow.iam.gserviceaccount.com'
    }
}


